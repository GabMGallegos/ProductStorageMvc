@model ProductStorageMvc.ViewModels.ProductCreateViewModel

@{
    ViewData["Title"] = "Add Product";
}

<section class="card">
    <div class="card-header">
        <h1>Add Product</h1>
        <p>Register a new product with its name, price, and quantity.</p>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success">
            @ViewBag.SuccessMessage
        </div>
    }

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-error">
            @ViewBag.ErrorMessage
        </div>
    }

    <form asp-controller="Products" asp-action="Create" method="post" class="product-form">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name"
                   class="form-control"
                   placeholder="Example: Keyboard" />
            <span asp-validation-for="Name" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price"></label>
            <input asp-for="Price"
                   class="form-control"
                   type="number"
                   min="0.01"
                   step="0.01"
                   inputmode="decimal"
                   placeholder="Example: 25.50" />
            <span asp-validation-for="Price" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity"
                   class="form-control"
                   type="number"
                   min="1"
                   step="1"
                   placeholder="Example: 10" />
            <span asp-validation-for="Quantity" class="validation-message"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary-button">
                Save Product
            </button>

            <a asp-controller="Products" asp-action="Index" class="secondary-button">
                View Products
            </a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}