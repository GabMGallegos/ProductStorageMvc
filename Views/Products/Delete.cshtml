@model ProductStorageMvc.ViewModels.ProductRowViewModel

@{
    ViewData["Title"] = "Delete Product";
}

<section class="card">
    <div class="card-header">
        <h1>Delete Product</h1>
        <p>Please confirm if you want to delete this product.</p>
    </div>

    <div class="alert alert-error">
        This action cannot be undone.
    </div>

    <div class="delete-summary">
        <p><strong>Id:</strong> @Model.Id</p>
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Price:</strong> $@Model.Price.ToString("F2")</p>
        <p><strong>Quantity:</strong> @Model.Quantity</p>
        <p><strong>Total Value:</strong> $@Model.TotalValue.ToString("F2")</p>
    </div>

    <form asp-controller="Products" asp-action="DeleteConfirmed" method="post" class="form-actions">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />

        <button type="submit" class="danger-button">
            Confirm Delete
        </button>

        <a asp-controller="Products" asp-action="Index" class="secondary-button">
            Cancel
        </a>
    </form>
</section>